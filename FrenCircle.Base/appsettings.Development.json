{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Async" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/log.txt",
                "rollingInterval": "Day"
              }
            }
          ]
        }
      }
    ]
  },
  "FCConfig": {
    "MongoDb": {
      "ConnectionString": "mongodb://localhost:27017",
      "Database": "local",
      "Collection": "CacheCollection"
    },
    "Urls": [
      {
        "ApiBaseUrl": "https://frencircle.com"
      }
    ],
    "ConnectionString": "",
    "Cryptography": {
      "Key": "YOUR_KEY",
      "IV": ""
    },
    "JwtSettings": {
      "ValidIssuer": "https://frencircle.com",
      "ValidAudience": "https://frencircle.com",
      "IssuerSigningKey": "YOUR_KEY"
    },
    "SmtpSettings": {
      "Server": "mail.frencircle.com",
      "Port": 587,
      "Username": "YOUR_USERNAME",
      "Password": "YOUR_PASSWORD",
      "FromName": "FrenCircle",
      "FromEmail": "mail@frencircle.com",
      "EnableSSL": false
    },
    "APIKey": "",
    "Toggles": {},
    "TelegramSettings": {
      "BotToken": "YOUR_BOT_TOKENM",
      "ChatId": "LOG_CHAT_ID",
      "ApiUrl": "https://api.telegram.org"
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 200,
      "Window": "00:01:00",
      "QueueLimit": 0
    },
    "Routes": {
      "api/messages/send": {
        "PermitLimit": 5,
        "Window": "00:01:00",
        "QueueLimit": 0
      }
    }
  }
}
